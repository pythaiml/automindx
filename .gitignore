# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Runtime artifacts
*.log
memory/*.json

# Models (downloaded at runtime; never commit the GGML/GGUF weights)
/models/
*.bin
*.gguf
*.ggml

# Env
.env
.env*.local
memory/*.jsonl
codephreak-console/node_modules/
codephreak-console/.next/

# sagi self-build output (runtime)
sagi/modules/*.md

# service-layer runtime
memory/*.db
*.db

# sAGI read/write history (runtime log)
sagi/.history/

# sAGI standing goal (runtime)
sagi/goal.txt

# sAGI gitmind memory tree (runtime object store)
sagi/.gitmind/

# sAGI point-of-save exports (runtime)
sagi/savepoints/

# spawned sAGI (runtime): subordinate children + sovereign peers
sagi/children/
sagi/sovereign/
